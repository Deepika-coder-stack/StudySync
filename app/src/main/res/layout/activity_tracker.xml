<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/softBlue"
    android:fillViewport="true"
    tools:context=".TrackerActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->

        <TextView
            android:id="@+id/trackerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Profile_Tracker"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/navyBlue"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>


        <!-- STUDY TIMER BUTTON -->

        <Button
            android:id="@+id/startStudyButton"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/start"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/blue"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/studyTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dot"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1C2C4C"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>


        <!-- STUDY PROGRESS CARD -->

        <androidx.cardview.widget.CardView
            android:id="@+id/chartCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- MONDAY -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mon"
                    android:textStyle="bold"
                    android:textColor="#1C2C4C"/>

                <ProgressBar
                    android:id="@+id/monBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="300"
                    android:progress="0"
                    android:progressTint="#4CAF50"/>


                <!-- TUESDAY -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tue"
                    android:textStyle="bold"
                    android:textColor="#1C2C4C"
                    android:layout_marginTop="8dp"/>

                <ProgressBar
                    android:id="@+id/tueBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="300"
                    android:progress="0"
                    android:progressTint="#2196F3"/>


                <!-- WEDNESDAY -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wed"
                    android:textStyle="bold"
                    android:textColor="#1C2C4C"
                    android:layout_marginTop="8dp"/>

                <ProgressBar
                    android:id="@+id/wedBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="300"
                    android:progress="0"
                    android:progressTint="#FFC107"/>


                <!-- THURSDAY -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/thu"
                    android:textStyle="bold"
                    android:textColor="#1C2C4C"
                    android:layout_marginTop="8dp"/>

                <ProgressBar
                    android:id="@+id/thuBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="300"
                    android:progress="0"
                    android:progressTint="#FF5722"/>


                <!-- FRIDAY -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/fri"
                    android:textStyle="bold"
                    android:textColor="#1C2C4C"
                    android:layout_marginTop="8dp"/>

                <ProgressBar
                    android:id="@+id/friBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="300"
                    android:progress="0"
                    android:progressTint="#9C27B0"/>


                <!-- SATURDAY -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sat"
                    android:textStyle="bold"
                    android:textColor="#1C2C4C"
                    android:layout_marginTop="8dp"/>

                <ProgressBar
                    android:id="@+id/satBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="300"
                    android:progress="0"
                    android:progressTint="#00BCD4"/>


                <!-- SUNDAY -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sun"
                    android:textStyle="bold"
                    android:textColor="#1C2C4C"
                    android:layout_marginTop="8dp"/>

                <ProgressBar
                    android:id="@+id/sunBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="300"
                    android:progress="0"
                    android:progressTint="#8BC34A"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- CARD ROW 1 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:backgroundTint="@color/peach"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView

                        android:text="@string/completed_f"
                        android:textSize="14sp"
                        android:textColor="#1C2C4C"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tasksCompleted"
                        android:text="@string/zero"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:backgroundTint="@color/mintGreen"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:text="@string/revision"
                        android:textSize="14sp"
                        android:textColor="#1C2C4C"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/revisionTasks"
                        android:text="@string/zero"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>


        <!-- CARD ROW 2 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:backgroundTint="@color/light_B"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:text="@string/miss"
                        android:textSize="14sp"
                        android:textColor="#1C2C4C"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tasksMissed"
                        android:text="@string/zero"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:backgroundTint="@color/pista"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:text="@string/avg"
                        android:textSize="14sp"
                        android:textColor="#1C2C4C"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/avgStudy"
                        android:text="@string/hrs"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>


        <!-- TODAY TIME -->

        <TextView
            android:id="@+id/todayTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/min"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1C2C4C"
            android:layout_marginTop="25dp"
            android:layout_gravity="center"/>

    </LinearLayout>

</ScrollView>