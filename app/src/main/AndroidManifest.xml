<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    >
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!-- LOGIN SCREEN (FIRST SCREEN) -->
        <activity
            android:name=".LoginActivity"
        android:theme="@style/Theme.StudySync"/>

        <receiver android:name=".ReminderReceiver"
            android:exported="false" />

        <!-- Main Screen -->
        <activity
            android:name="com.igdtuw.studysync.MainActivity"
            android:exported="false" />

        <activity
            android:name="com.igdtuw.studysync.MainScreen"
            android:exported="false" />

        <!-- Splash Screen (Launcher) -->
        <activity
            android:name="com.igdtuw.studysync.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- BASIC INFO SCREEN -->
        <activity android:name=".BasicInfoActivity" />

        <!-- TASK SCREEN -->
        <activity android:name=".TaskActivity" />

    </application>
</manifest>